node_modules
dist
*.local
.DS_Store
node_modules/.tmp

# data files are loaded at runtime, never committed; the DuckDB node smoke test
# also writes a *.parquet into CWD during `npm test`.
*.parquet
# …except the committed acceptance fixture referenced by fixtures/acceptance.sql.
!fixtures/metrics.parquet
# …and the bundled demo dataset (loaded at runtime by the onboarding screen).
!public/demo/users.parquet
# …and the M9 sample gallery slice (built by scripts/prepSamples.mjs).
!public/samples/taxi.parquet

# The export round-trip test runs DuckDB `COPY TO`, which writes a real file into
# CWD (qb-export.parquet is caught by *.parquet above; these two are not).
qb-export.csv
tmp_qb-export.*
